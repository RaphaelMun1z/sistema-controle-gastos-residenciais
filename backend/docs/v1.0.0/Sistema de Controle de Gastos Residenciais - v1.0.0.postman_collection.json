                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const resposta = pm.response.json();",
                  "",
                  "    if (resposta.personId) {",
                  "        pm.collectionVariables.set(\"personId\", resposta.personId);",
                  "    }",
                  "",
                  "    if (resposta.accountId) {",
                  "        pm.collectionVariables.set(\"accountId\", resposta.accountId);",
                  "    }",
                  "}"
                ]
              }
            }
